{
  "name": "@scrapito/agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "scrap-agent": "./src/cli.ts"
  },
  "scripts": {
    "scrap-agent": "bun run src/cli.ts",
    "build": "bun build src/cli.ts --outdir dist --target bun --packages external",
    "typecheck": "tsc --noEmit",
    "test": "bun test src"
  },
  "dependencies": {
    "@oh-my-pi/pi-coding-agent": "17.0.4",
    "@scrapito/contracts": "workspace:*",
    "@scrapito/ingest": "workspace:*",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bun": "1.1.14",
    "typescript": "5.7.2"
  }
}

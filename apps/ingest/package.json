{
  "name": "@scrapito/ingest",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "scrap-ingest": "./src/cli/index.ts"
  },
  "scripts": {
    "scrap-ingest": "bun run src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test src",
